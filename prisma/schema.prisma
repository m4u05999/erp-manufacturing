generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum DealStage {
  LEAD
  QUALIFIED
  QUOTATION
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ProductionOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(VIEWER)
  department    String?
  phone         String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedLeads      Lead[]
  assignedProjects   Project[]
  assignedTasks      Task[]
  assignedTickets    SupportTicket[]
  attendanceRecords  Attendance[]
  notifications      Notification[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  userId     String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String?
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Lead {
  id          String    @id @default(cuid())
  companyName String
  contactName String
  contactEmail String?
  contactPhone String?
  source      String?
  stage       DealStage @default(LEAD)
  score       Int       @default(0)
  notes       String?
  estimatedValue Float?
  assignedTo  String?
  assignedUser User?    @relation(fields: [assignedTo], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  quotations Quotation[]
  projects   Project[]

  @@index([stage])
  @@index([assignedTo])
  @@map("leads")
}

model Quotation {
  id          String         @id @default(cuid())
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  quoteNumber String         @unique
  items       Json
  subtotal    Float
  discount    Float          @default(0)
  taxRate     Float          @default(0)
  total       Float
  validUntil  DateTime?
  status      String         @default("DRAFT")
  createdBy   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([leadId])
  @@index([status])
  @@map("quotations")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  leadId      String?
  lead        Lead?         @relation(fields: [leadId], references: [id])
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  actualCost  Float?
  location    String?
  managerId   String?
  manager     User?         @relation(fields: [managerId], references: [id])
  clientName  String?
  clientPhone String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tasks             Task[]
  dailyReports      DailyReport[]
  purchaseOrders    PurchaseOrder[]
  productionOrders  ProductionOrder[]
  engineeringDrawings Drawing[]
  supportTickets    SupportTicket[]
  expenses          Expense[]

  @@index([status])
  @@index([managerId])
  @@map("projects")
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  dueDate     DateTime?
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@map("tasks")
}

model DailyReport {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportDate  DateTime @default(now())
  summary     String
  photos      Json?
  weather     String?
  delays      String?
  notes       String?
  submittedBy String?
  createdAt   DateTime @default(now())

  @@index([projectId, reportDate])
  @@map("daily_reports")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  contactEmail String?
  contactPhone String?
  address     String?
  category    String?
  rating      Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  supplierEvaluations SupplierEvaluation[]

  @@map("suppliers")
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  poNumber        String              @unique
  supplierId      String
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  projectId       String?
  project         Project?            @relation(fields: [projectId], references: [id])
  items           Json
  totalAmount     Float
  status          PurchaseOrderStatus @default(DRAFT)
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  notes           String?
  createdBy       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([supplierId])
  @@index([projectId])
  @@map("purchase_orders")
}

model InventoryItem {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  category    String?
  unit        String   @default("pcs")
  quantity    Float    @default(0)
  minQuantity Float    @default(0)
  unitCost    Float?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("inventory_items")
}

model ProductionOrder {
  id              String               @id @default(cuid())
  orderNumber     String               @unique
  projectId       String?
  project         Project?             @relation(fields: [projectId], references: [id])
  productName     String
  quantity        Int
  status          ProductionOrderStatus @default(PENDING)
  priority        String               @default("MEDIUM")
  scheduledDate   DateTime?
  completedDate   DateTime?
  notes           String?
  assignedTo      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  qualityChecks QualityCheck[]

  @@index([status])
  @@index([projectId])
  @@map("production_orders")
}

model QualityCheck {
  id              String   @id @default(cuid())
  productionOrderId String
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  stage           String
  passed          Boolean
  notes           String?
  checkedBy       String?
  checkedAt       DateTime @default(now())

  @@index([productionOrderId])
  @@map("quality_checks")
}

model SupplierEvaluation {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  score       Int
  criteria    Json
  notes       String?
  evaluatedBy String?
  evaluatedAt DateTime @default(now())

  @@index([supplierId])
  @@map("supplier_evaluations")
}

model Drawing {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  version     Int      @default(1)
  fileUrl     String
  status      String   @default("DRAFT")
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, version])
  @@map("drawings")
}

model SupportTicket {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  customerName String
  customerPhone String?
  subject     String
  description String
  category    String?
  priority    String   @default("MEDIUM")
  status      String   @default("OPEN")
  assignedTo  String?
  assignedUser User?   @relation(fields: [assignedTo], references: [id])
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([projectId])
  @@map("support_tickets")
}

model Attendance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  location   String?
  status     String   @default("PRESENT")
  notes      String?
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@map("attendance")
}

model Expense {
  id          String   @id @default(cuid())
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  category    String
  description String
  amount      Float
  receiptUrl  String?
  approvedBy  String?
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@map("expenses")
}
